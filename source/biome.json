{
    "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
    "organizeImports": {
        "enabled": true
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "formatter": {
        "enabled": true
    },
    "files": {
        "ignore": [
            "vendor",
            "node_modules",
            "public",
            "bootstrap/ssr",
            "resources/js/actions/**",
            "resources/js/components/ui/*",
            "resources/js/components/shadcn/ui/*",
            "resources/js/routes/**",
            "resources/js/wayfinder/**",
            "resources/views/mail/*"
        ]
    }
}
