{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "git:*",
      "docker:*"
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git push)",
      "Bash(gh issue view *)",
      "Bash(gh label *)",
      "Bash(vendor/bin/sail artisan test*)",
      "Bash(pnpm test*)",
      "Bash(pnpm run test*)",
      "Bash(vendor/bin/sail pnpm test*)",
      "Bash(vendor/bin/sail pnpm run test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm format*)",
      "Bash(pnpm run format*)",
      "Bash(pnpm check*)",
      "Bash(pnpm run check*)",
      "Bash(pnpm tc*)",
      "Bash(pnpm run tc*)",
      "Bash(vendor/bin/sail pnpm lint*)",
      "Bash(vendor/bin/sail pnpm run lint*)",
      "Bash(vendor/bin/sail pnpm format*)",
      "Bash(vendor/bin/sail pnpm run format*)",
      "Bash(vendor/bin/sail pnpm check*)",
      "Bash(vendor/bin/sail pnpm run check*)",
      "Bash(vendor/bin/sail bin pint*)",
      "Write(*.md)",
      "Write(.claude/skills/**)",
      "Write(**/*.tsx)",
      "Write(**/*.ts)",
      "Write(**/*.php)",
      "Write(**/*.css)",
      "Write(**/*.blade.php)",
      "Write(**/*.json)",
      "Write(**/*.md)",
      "Read(*.md)",
      "Read(**/*.md)",
      "Edit(/.claude/skills/**)",
      "Edit(**/*.tsx)",
      "Edit(**/*.ts)",
      "Edit(**/*.php)",
      "Edit(**/*.css)",
      "Edit(**/*.blade.php)",
      "Edit(**/*.json)",
      "Edit(**/*.md)",
      "Bash(mkdir -p *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Bash(grep *.env)",
      "Bash(grep *.env.*)"
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  }
}
